---
title: "Portfolio";
import { Tweet, Vimeo, YouTube } from "astro-embed";
import Layout from "@layouts/Layout.astro";

import { Image } from "astro:assets";
import thuanFace from "@assets/images/new-profile.png";
import editLikeYouGiveAF from "@assets/images/af.png";
---

<Layout>
  <!--<Header activeNav="portfolio" />-->
  <main id="main-content">
    <section id="hero">
      <h1>
        Thuan Pham<div class="text-2xl">
          / Video Editor<div></div>
          <div>
            <Image
              id="af"
              class="sepia-0"
              src={editLikeYouGiveAF}
              format={"webp"}
              alt="edit like you give a f"
              loading="lazy"
            />
<div class="relative inline-block">
  <div class="absolute inset-0 rounded-full bg-amber-300/40 blur-3xl dark:bg-amber-500/20"></div>

  <Image
    class="relative mb-3 rounded-full"
    src={thuanFace}
    width={350}
    format={"webp"}
    alt="Thuan Pham"
    loading="lazy"
  />
</div>
<div class="mt-10 text-xl">
              <p>Focused on building long-term brands and real revenue</p>
              <div>
<p   id="waitlist"
 class="border-l-4 border-amber-200 dark:border-amber-900 bg-amber-50 dark:bg-amber-950/30 rounded-r-lg px-4 py-3 italic text-stone-600 dark:text-stone-300">
  currently at capacity, join the waitlist and i’ll let you know when i’m available
</p>
            </div>
            </div>
<iframe src="https://docs.google.com/forms/d/e/1FAIpQLSdctI_yCPq3AJ7GmC_nUaVbdFKvzqR9WVxRwZRfccYJf24JxA/viewform?embedded=true" width="640" height="763" frameborder="0" marginheight="0" marginwidth="0">Loading…</iframe>
            <p>Questions? Email me at: <a href="mailto:cutbypham"
                  class="text-xl font-bold text-green-500 decoration-dashed hover:text-green-400 hover:underline"
                  >cutbypham@gmail.com</a
                >
              </p>
          </div>
          <section id="lifestyle" class="mb-8 mt-8">
            <br />
            <div style="padding:50% 0 0 0;position:relative;">
              <iframe
                src="https://player.vimeo.com/video/1067588833?badge=0&autopause=0&portrait=false&title=false&byline=false&badge=false"
                frameborder="0"
                allow="autoplay; fullscreen; picture-in-picture; clipboard-write"
                style="position:absolute;top:0;left:0;width:100%;height:100%;"
                title="Ho Chi Minh City ｜ phothrottle"></iframe>
            </div><script src="https://player.vimeo.com/api/player.js"></script>
            <br />
            <div style="padding:50% 0 0 0;position:relative;">
              <iframe
                src="https://player.vimeo.com/video/1067583918?badge=0&autopause=0&portrait=false&title=false&byline=false&badge=false"
                frameborder="0"
                allow="autoplay; fullscreen; picture-in-picture; clipboard-write"
                style="position:absolute;top:0;left:0;width:100%;height:100%;"
                title="Ho Chi Minh City ｜ phothrottle"></iframe>
            </div><script src="https://player.vimeo.com/api/player.js"></script>
            <br />
            <div style="padding:50% 0 0 0;position:relative;">
              <iframe
                src="https://player.vimeo.com/video/952803807?badge=0&autopause=0&portrait=false&title=false&byline=false&badge=false"
                frameborder="0"
                allow="autoplay; fullscreen; picture-in-picture; clipboard-write"
                style="position:absolute;top:0;left:0;width:100%;height:100%;"
                title="Ho Chi Minh City ｜ phothrottle"></iframe>
            </div><script src="https://player.vimeo.com/api/player.js"></script>
            <br />
            <div style="padding:50% 0 0 0;position:relative;">
              <iframe
                src="https://player.vimeo.com/video/952801928?badge=0&autopause=0&portrait=false&title=false&byline=false&badge=false"
                frameborder="0"
                allow="autoplay; fullscreen; picture-in-picture; clipboard-write"
                style="position:absolute;top:0;left:0;width:100%;height:100%;"
                title="Daikoku Parking Area： Cars and Coffee ｜ phothrottle"
              ></iframe>
            </div><script src="https://player.vimeo.com/api/player.js"></script>
            <br />
          </section>
<section>
  <button
    type="button"
    id="shake-button"
    class="mb-8 me-2 ml-2 rounded-lg bg-green-700 px-5 py-2.5 text-5xl font-medium text-white hover:bg-green-800 focus:outline-none focus:ring-4 focus:ring-green-300 dark:bg-green-600 dark:hover:bg-green-700 dark:focus:ring-green-800"
  >
    Let's work together
  </button>

<script is:inline>
  document
    .getElementById("shake-button")
    .addEventListener("click", function () {
      document
        .getElementById("waitlist")
        .scrollIntoView({ behavior: "smooth" });
    });
</script>
</section>
        </div>
        <style>
          #hero {
            @apply pb-6 pt-8;
          }
          #hero h1 {
            @apply my-4 inline-block text-3xl font-bold sm:my-8 sm:text-5xl;
          }
          #hero .rss-link {
            @apply mb-6;
          }
          #hero .rss-icon {
            @apply mb-2 h-6 w-6 scale-110 fill-skin-accent sm:mb-3 sm:scale-125;
          }
          #hero p {
            @apply my-4;
          }

          #shake {
            animation: tilt-n-move-shaking-avata 1.5s infinite;
          }

          #shake-button:hover {
            animation: tilt-n-move-shaking 0.25s infinite;
          }

          #button-heading:focus {
            animation: horizontal-shaking 0.01s infinite;
          }

          #af {
            margin-bottom: -60px;
          }

          #af:hover {
            animation: horizontal-shaking 0.25s infinite;
          }

          @keyframes tilt-n-move-shaking-avata {
            0% {
              transform: translate(0, 0) rotate(0deg);
              filter: blur(0.1px);
            }
            25% {
              transform: translate(2px, 2px) rotate(2deg);
              filter: blur(0.25px);
            }
            50% {
              transform: translate(0, 0) rotate(0eg);
              filter: blur(0.5px);
            }
            75% {
              transform: translate(-2px, 2px) rotate(-2deg);
            }
            100% {
              transform: translate(0, 0) rotate(0deg);
              filter: blur(1px);
            }
          }

          @keyframes tilt-n-move-shaking {
            0% {
              transform: translate(0, 0) rotate(0deg);
              filter: blur(0.1px);
            }
            25% {
              transform: translate(5px, 5px) rotate(5deg);
              filter: blur(0.25px);
            }
            50% {
              transform: translate(0, 0) rotate(0eg);
              filter: blur(0.5px);
            }
            75% {
              transform: translate(-5px, 5px) rotate(-5deg);
            }
            100% {
              transform: translate(0, 0) rotate(0deg);
              filter: blur(1px);
            }
          }

          @keyframes horizontal-shaking {
            0% {
              transform: translateX(0);
              filter: blur(1px);
            }
            25% {
              transform: translateX(10px);
              filter: blur(2px);
            }
            50% {
              transform: translateX(-10px);
              filter: blur(3px);
            }
            75% {
              transform: translateX(10px);
              filter: blur(4px);
            }
            100% {
              transform: translateX(0);
              filter: blur(5px);
            }
          }

          @keyframes horizontal-shaking {
            0% {
              transform: translateX(0);
              filter: blur(1px);
            }
            25% {
              transform: translateX(1px);
              filter: blur(2px);
            }
            50% {
              transform: translateX(-1px);
              filter: blur(3px);
            }
            75% {
              transform: translateX(1px);
              filter: blur(4px);
            }
            100% {
              transform: translateX(0);
              filter: blur(5px);
            }
          }
        </style>
      </h1>
    </section>
  </main></Layout
>
